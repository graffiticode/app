# Graffiticode API + auth service (defaults shown)
NEXT_PUBLIC_GC_API_URL=https://api.graffiticode.org
NEXT_PUBLIC_GC_AUTH_URL=https://auth.graffiticode.org

# Privy (email magic-link sign-in). Get from the Privy dashboard.
NEXT_PUBLIC_PRIVY_APP_ID=

# Firebase Web API key for the graffiticode auth project — used server-side to
# exchange a Graffiticode api key for a Firebase ID token (api-credentials).
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase Admin credentials for the graffiticode-app project (item lookups).
# Point at a service-account JSON. On Cloud Run this is provided by the runtime
# service account instead.
GOOGLE_APPLICATION_CREDENTIALS=
