{
  "name": "graffiticode-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_NO_WARNINGS=1 next dev",
    "build": "cross-env NODE_NO_WARNINGS=1 next build",
    "start": "cross-env NODE_NO_WARNINGS=1 next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gcp:build": "gcloud builds submit --config cloudbuild.yaml --project graffiticode-app --substitutions=_TAG=$(git rev-parse --short HEAD 2>/dev/null || echo 'latest')",
    "gcp:logs": "gcloud logging read 'resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"app\"' --project graffiticode-app --limit 100 --format='table(timestamp,severity,httpRequest.status,httpRequest.requestMethod,httpRequest.requestUrl,httpRequest.latency,textPayload)'",
    "gcp:logs:tail": "gcloud beta run services logs tail app --project graffiticode-app --region us-central1"
  },
  "dependencies": {
    "@ethereumjs/util": "^8.0.3",
    "@graffiticode/auth": "^2.1.2",
    "@graffiticode/auth-react": "*",
    "@headlessui/react": "^1.7.16",
    "@heroicons/react": "^2.1.1",
    "@privy-io/react-auth": "^1.99.1",
    "@privy-io/server-auth": "^1.32.5",
    "@tanstack/react-query": "^5.84.1",
    "bent": "^7.3.12",
    "classnames": "^2.5.1",
    "firebase": "^9.23.0",
    "firebase-admin": "^13.5.0",
    "next": "^15.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactfire": "^4.2.3",
    "swr": "^2.0.0",
    "viem": "^2.33.3",
    "wagmi": "^2.16.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.15",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.4.6",
    "postcss": "^8.4.28",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.2"
  }
}
