  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts"
  },
  "peerDependencies": {
    "@ethereumjs/util": "^8.0.3",
    "@graffiticode/auth": "^2.1.2",
    "@privy-io/react-auth": "^1.99.1",
    "@tanstack/react-query": "^5.84.1",
    "firebase": "^9.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactfire": "^4.2.3",
    "swr": "^2.0.0",
    "viem": "^2.33.3",
    "wagmi": "^2.16.1"
  }
}
