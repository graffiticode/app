{
  "name": "@graffiticode/auth-react",
  "version": "0.4.0",
  "description": "Shared Graffiticode auth: SIWE (wallet) + Privy email sign-in + Firebase token exchange + cross-app SSO. Consumed by app.graffiticode.org and console.graffiticode.org.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
